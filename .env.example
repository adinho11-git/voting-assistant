# Copy to .env and fill in real values.
# For development without MongoDB, leave USE_MOCK_DATA=true.

# When true (or MONGODB_URI is empty) the app uses in-memory mock data.
# Set to false in production once MONGODB_URI is configured.
USE_MOCK_DATA=true

# MongoDB Atlas connection string (optional in mock mode).
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# MONGODB_URI=

# Admin password — required to access /admin.
ADMIN_PASSWORD=zhaw2026admin
